# 沙箱配置
SANDBOX_IMAGE=
SANDBOX_MEM_LIMIT=
SANDBOX_CPU_SHARES=
SANDBOX_NETWORK_DISABLED=
SANDBOX_RUN_USER=
SANDBOX_EXEC_TIMEOUT=
SANDBOX_CONTAINER_OP_TIMEOUT=
SANDBOX_MAX_TENANT_CONCURRENCY=
ZOMBIE_CLEAN_INTERVAL=

#基础配置
MAX_CODE_LENGTH=
LOG_LEVEL=
PROMETHEUS_PORT=

# DashScope / LiteLLM 配置
DASHSCOPE_API_KEY=sk-xxxxxxxxx
DEERFLOW_RUNTIME_MODE=sidecar
DEERFLOW_SIDECAR_URL=http://127.0.0.1:8765
DEERFLOW_CONFIG_PATH=
DEERFLOW_MODEL_NAME=
ANALYSIS_RUNTIME_POLICY_PATH=

# API 暴露与认证
API_ALLOW_ORIGINS=http://127.0.0.1:8501,http://localhost:8501
API_AUTH_REQUIRED=false
API_AUTH_TOKENS_JSON={"viewer-token":{"tenant_id":"demo-tenant","workspace_id":"demo-workspace","role":"viewer","subject":"viewer-user"},"operator-token":{"tenant_id":"demo-tenant","workspace_id":"demo-workspace","role":"operator","subject":"operator-user"},"admin-token":{"tenant_id":"demo-tenant","workspace_id":"demo-workspace","role":"admin","subject":"admin-user"}}
API_AUTH_USERS_JSON={"alice":{"password":"alice-pass","role":"admin","subject":"alice-user","grants":[{"tenant_id":"demo-tenant","workspace_id":"demo-workspace"},{"tenant_id":"finance-tenant","workspace_id":"finance-ws"}]}}
API_SESSION_SECRET=change-me-in-production
API_SESSION_TTL_SECONDS=43200
API_ENABLE_POLICY_API=false
API_ENABLE_DEMO_TRACE=false
API_ENABLE_DIAGNOSTICS=false
STRICT_PERSISTENCE=false

# 数据库配置 (如果使用 docker-compose 启动在本地，使用默认值即可)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=kag_db
POSTGRES_HOST=localhost
POSTGRES_URI=postgresql://postgres:postgres123@localhost:5432/kag_db

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

QDRANT_HOST=localhost
QDRANT_PORT=6333

# 系统超参数
LOG_LEVEL=DEBUG
CONTEXT_BUDGET_TOKENS=5000
