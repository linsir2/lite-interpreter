# Sandbox
SANDBOX_IMAGE=
SANDBOX_MEM_LIMIT=2g
SANDBOX_CPU_SHARES=
SANDBOX_NETWORK_DISABLED=
SANDBOX_RUN_USER=
SANDBOX_EXEC_TIMEOUT=
SANDBOX_CONTAINER_OP_TIMEOUT=
SANDBOX_MAX_TENANT_CONCURRENCY=
ZOMBIE_CLEAN_INTERVAL=

# Core runtime
MAX_CODE_LENGTH=
LOG_LEVEL=INFO
PROMETHEUS_PORT=8000
CONTEXT_BUDGET_TOKENS=5000
HARNESS_POLICY_PATH=
ANALYSIS_RUNTIME_POLICY_PATH=
GRAPH_LEXICON_PATH=

# LLM
DASHSCOPE_API_KEY=sk-xxxxxxxxx

# Native dynamic exploration
DYNAMIC_NATIVE_MAX_STEPS=6
DYNAMIC_NATIVE_TIMEOUT=300
DYNAMIC_NATIVE_MODEL=reasoning_model

# API auth
API_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
API_AUTH_REQUIRED=true
API_AUTH_TOKENS_JSON={"viewer-token":{"tenant_id":"demo-tenant","workspace_id":"demo-workspace","role":"viewer","subject":"viewer-user"},"operator-token":{"tenant_id":"demo-tenant","workspace_id":"demo-workspace","role":"operator","subject":"operator-user"},"admin-token":{"tenant_id":"demo-tenant","workspace_id":"demo-workspace","role":"admin","subject":"admin-user"}}
API_LOCAL_TENANT_ID=local-tenant
API_LOCAL_WORKSPACE_ID=local-workspace
API_ENABLE_POLICY_API=false
API_ENABLE_DIAGNOSTICS=false

# Upload limits
UPLOAD_MAX_FILE_BYTES=26214400
UPLOAD_MAX_REQUEST_BYTES=52428800

# Datastores
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=kag_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_URI=postgresql://postgres:postgres123@localhost:5432/kag_db
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Retrieval and graph tuning
CHUNK_SIZE=800
CHUNK_OVERLAP=150
EMBEDDING_DIM=1536
CLASSIFIER_SMALL_THRESHOLD=1500
CLASSIFIER_MEDIUM_THRESHOLD=50000
MRL_DIMENSION=256
EMBEDDING_MODEL_NAME=embedding_model
EMBEDDING_BATCH_SIZE=32
EXTRACTION_MODEL_NAME=reasoning_model
GRAPH_TYPES=semantic,temporal,causal,entity
GRAPH_EXTRACTOR_VERSION=2.0
GRAPH_STRUCTURED_LLM_ENABLED=false
PARENT_CHUNK_SIZE=2000
CONTEXT_MAX_TOKENS=4000
COMPRESSION_RATIO=0.3
SELECTION_STRATEGY=rrf
FORMAT_TEMPLATE=structured
CONTEXT_MODEL_NAME=reasoning_model
BM25_TOP_K=20
VECTOR_TOP_K=20
GRAPH_TOP_K=10
HYBRID_RRF_K=60
RERANK_TOP_K=15
MAX_RETRIEVAL_TOP_K=50
RERANK_CANDIDATE_LIMIT=60
RERANK_CANDIDATE_MULTIPLIER=4
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
